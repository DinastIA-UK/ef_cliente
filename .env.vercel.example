# Variáveis necessárias para produção na Vercel

# Supabase (operações de escrita na tabela 'boxes')
SUPABASE_URL=https://SEU_PROJETO.supabase.co
SUPABASE_SERVICE_KEY=sua_service_key_aqui

# Credenciais do Prisma Box (se o scraping exige login)
PRISMA_USERNAME=seu_usuario
PRISMA_PASSWORD=sua_senha

# Ambiente
NODE_ENV=production

# Observações:
# - Não defina PORT/API_PORT na Vercel; a plataforma gerencia a porta.
# - Callback em produção deve ser HTTPS e público (não localhost).
# - SUPABASE_ANON_KEY não é necessário aqui (o código usa SERVICE_KEY para escrita).
# - PRISMA_BOX_URL é opcional e não é usado diretamente no código atual.

